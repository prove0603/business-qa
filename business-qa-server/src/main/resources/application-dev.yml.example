# Copy this file to application-dev.yml and fill in actual values
# application-dev.yml is excluded from Git

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/business_qa
    username: postgres
    password: your_postgres_password
  ai:
    openai:
      api-key: sk-your-dashscope-api-key
    mcp:
      client:
        enabled: true
        sse:
          connections:
            businessQaMcpServer:
              url: http://localhost:8092
              sse-endpoint: /sse

qa:
  git:
    username: your-git-username
    password: your-git-password-or-token
